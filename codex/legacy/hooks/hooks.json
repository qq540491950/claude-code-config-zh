{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Cmd",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/pretool-risk-blocker.js"
          }
        ],
        "description": "阻断明显高风险的删除/格式化命令（跨 Bash/PowerShell/Cmd，收紧关键字误报）"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/pretool-sensitive-write-check.js"
          }
        ],
        "description": "写入前检测常见敏感信息模式并提醒"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/stop-delivery-reminder.js"
          }
        ],
        "description": "每次响应后给出最小交付检查提醒"
      }
    ]
  }
}
